---
import "@styles/global.css";
import Meta from "@components/seo/Meta.astro";
import StructuredData from "@components/seo/StructuredData.astro";
import Header from "@components/site/Header.astro";
import Footer from "@components/site/Footer.astro";
import { CookieConsent } from "@components/site/CookieConsent";

interface Props {
  title: string;
  description: string;
  path?: string;
  includeFaq?: boolean;
  customFaq?: Array<{ q: string; a: string }>;
  fullHeight?: boolean;
  keywords?: string;
}

const {
  title,
  description,
  path,
  includeFaq = false,
  customFaq,
  fullHeight = false,
  keywords,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      // Google Consent Mode v2 Initializer
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}

      var savedConsent = typeof localStorage !== 'undefined' ? localStorage.getItem('cookie-consent') : null;
      var isGranted = (savedConsent === 'granted' || savedConsent === 'accepted');

      gtag('consent', 'default', {
        'ad_storage': isGranted ? 'granted' : 'denied',
        'ad_user_data': isGranted ? 'granted' : 'denied',
        'ad_personalization': isGranted ? 'granted' : 'denied',
        'analytics_storage': isGranted ? 'granted' : 'denied',
        'wait_for_update': 500
      });
    </script>
    <script
      src="https://quge5.com/88/tag.min.js"
      data-zone="262899"
      async
      data-cfasync="false"
      is:inline></script>
    <meta charset="UTF-8" />
    <Meta
      title={title}
      description={description}
      path={path}
      keywords={keywords}
    />
    <StructuredData includeFaq={includeFaq} customFaq={customFaq} />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-TKJSHMQD3E"
    ></script>
    <script is:inline>
      // Set theme early to avoid FOUC.
      (function () {
        try {
          var stored = JSON.parse(
            localStorage.getItem("json-formatter-pro") || "{}",
          );
          var pref = stored.state && stored.state.theme;
          // Validate theme is one of the valid values
          if (pref !== "light" && pref !== "dark" && pref !== "auto") {
            pref = undefined;
          }
          var mode =
            pref === "light" || pref === "dark"
              ? pref
              : window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";
          document.documentElement.dataset.theme = mode;
        } catch (_) {
          document.documentElement.dataset.theme = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches
            ? "dark"
            : "light";
        }
      })();

      // Google Analytics
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-TKJSHMQD3E");
    </script>
  </head>
  <body class="min-h-screen bg-bg text-fg antialiased">
    <a class="skip-link" href="#main">Skip to editor</a>
    <div
      class:list={[
        "flex min-h-screen flex-col",
        fullHeight && "h-screen overflow-hidden",
      ]}
    >
      <Header />
      <main id="main" class:list={["flex-1", fullHeight && "min-h-0"]}>
        <slot />
      </main>
      {!fullHeight && <Footer />}
    </div>
    <CookieConsent client:load />
  </body>
</html>
