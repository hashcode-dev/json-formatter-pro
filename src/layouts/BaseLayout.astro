---
import '@styles/global.css';
import Meta from '@components/seo/Meta.astro';
import StructuredData from '@components/seo/StructuredData.astro';
import Header from '@components/site/Header.astro';
import Footer from '@components/site/Footer.astro';
import { CookieConsent } from '@components/site/CookieConsent';

interface Props {
  title: string;
  description: string;
  path?: string;
  includeFaq?: boolean;
  fullHeight?: boolean;
  keywords?: string;
}

const {
  title, description, path,
  includeFaq = false, fullHeight = false,
  keywords,
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <Meta title={title} description={description} path={path} keywords={keywords} />
    <StructuredData includeFaq={includeFaq} />
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>
    <script is:inline>
      // Set theme early to avoid FOUC.
      (function () {
        try {
          var stored = JSON.parse(localStorage.getItem('json-formatter-pro') || '{}');
          var pref = stored.state && stored.state.theme;
          // Validate theme is one of the valid values
          if (pref !== 'light' && pref !== 'dark' && pref !== 'auto') {
            pref = undefined;
          }
          var mode = pref === 'light' || pref === 'dark'
            ? pref
            : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.dataset.theme = mode;
        } catch (_) {
          document.documentElement.dataset.theme =
            window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-bg text-fg antialiased">
    <a class="skip-link" href="#main">Skip to editor</a>
    <div class:list={['flex min-h-screen flex-col', fullHeight && 'h-screen overflow-hidden']}>
      <Header />
      <main id="main" class:list={['flex-1', fullHeight && 'min-h-0']}>
        <slot />
      </main>
      {!fullHeight && <Footer />}
    </div>
    <CookieConsent client:load />
  </body>
</html>
