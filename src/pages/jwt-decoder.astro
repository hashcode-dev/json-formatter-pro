---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { FormatterApp } from "@components/formatter/FormatterApp";

const title = "JWT Inspector & Token Decoder Pro - Free & Secure";
const description =
  "Decode JSON Web Tokens (JWT) safely in your browser. Inspect Header, Claims Payload, Signature, Issued At, and Expiration timestamps with 100% client-side privacy.";
const keywords =
  "jwt decoder, jwt inspector, decode jwt online, view jwt claims, check jwt expiration, jwt tool, client side jwt debugger, OAuth token inspector";

const faqs = [
  {
    q: "Is it safe to decode secret bearer JWT tokens on this website?",
    a: "Yes, 100% safe. Token decoding is performed entirely inside your browser memory using Base64URL string decoding algorithms. Your bearer tokens, secret claims, and authorization keys are NEVER sent over any network or stored on any server."
  },
  {
    q: "What components of a JWT token are decoded?",
    a: "A standard JWT consists of three dot-separated Base64URL strings: Header (algorithm & token type), Payload (claims like `sub`, `iss`, `aud`, `exp`, `iat`, user roles), and Signature. Our inspector decodes and formats all three sections cleanly!"
  },
  {
    q: "How does the token expiration status check work?",
    a: "Our decoder parses the Unix timestamp inside the `exp` (Expiration Time) and `iat` (Issued At) claims, comparing them against the current system time to explicitly inform you whether the token is currently valid, expired, or not yet active."
  },
  {
    q: "Does decoding a JWT token verify its signature key?",
    a: "Decoding extracts and displays the unencrypted Header and Payload claims. Signature verification requires the secret key or public RSA/ECDSA key, which remains strictly on your authorization server."
  }
];
---

<BaseLayout title={title} description={description} keywords={keywords} path="/jwt-decoder" customFaq={faqs}>
  <section class="mx-auto max-w-[1400px] px-4 pt-6">
    <p class="text-xs font-medium uppercase tracking-wide text-subtle">Security & Inspector</p>
    <h1 class="mt-1 text-2xl font-semibold tracking-tight text-fg sm:text-3xl">JWT Inspector & Token Decoder Pro</h1>
    <p class="mt-1 max-w-2xl text-sm text-subtle">Decode JSON Web Token headers, payload claims, signature hashes, and human-readable expiration timestamps 100% locally.</p>
  </section>

  <section class="mx-auto mt-4 h-[calc(100vh-14rem)] min-h-[520px] max-w-[1400px] px-2 sm:px-4">
    <div class="card h-full overflow-hidden shadow-pop">
      <FormatterApp client:only="react" initialMode="jwt" />
    </div>
  </section>

  <section class="mx-auto mt-12 max-w-[1400px] px-4 pb-16 space-y-8">
    <article class="card p-6 md:p-8 space-y-6 text-sm text-subtle leading-relaxed">
      <h2 class="text-xl font-bold text-fg">Complete Guide to Secure Online JWT Token Inspection</h2>
      <p>
        <strong>JSON Web Tokens (JWT)</strong> defined in RFC 7519 are the foundational standard for authorization and authentication across web applications, OAuth 2.0 / OpenID Connect (OIDC) identity providers, and microservice APIs.
      </p>
      <p>
        When debugging authentication issues, developers need to inspect bearer tokens to verify user claims, roles, scopes, and expiration dates. However, pasting production JWT tokens into unverified online websites poses a severe security risk if those sites transmit tokens to remote servers.
      </p>
      <p>
        <strong>JWT Inspector Pro</strong> guarantees zero network transmission. It decodes and formats your JWT tokens entirely inside your local browser instance.
      </p>

      <h3 class="text-lg font-semibold text-fg">How to Inspect & Decode JWT Tokens Online</h3>
      <ol class="list-decimal pl-5 space-y-2">
        <li><strong>Paste Your JWT:</strong> Paste your `eyJ...` encoded JWT string into the editor pane.</li>
        <li><strong>Instant Decoding:</strong> The tool automatically parses the Base64URL string into three distinct sections: Header, Payload, and Signature.</li>
        <li><strong>Review Claims & Expiration:</strong> Inspect token metadata including algorithm (`HS256`, `RS256`), user ID (`sub`), scopes, and human-readable expiration timestamps.</li>
      </ol>

      <h3 class="text-lg font-semibold text-fg">Anatomy of a JSON Web Token (JWT)</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pt-2">
        <div class="rounded-lg border border-border bg-surface p-4">
          <h4 class="font-semibold text-fg mb-1">1. Header (Red)</h4>
          <p class="text-xs">Specifies the token type (`JWT`) and cryptographic signing algorithm (e.g. `HS256`, `RS256`, `ES256`).</p>
        </div>
        <div class="rounded-lg border border-border bg-surface p-4">
          <h4 class="font-semibold text-fg mb-1">2. Payload (Purple)</h4>
          <p class="text-xs">Contains the claims data including standard claims (`iss`, `sub`, `aud`, `exp`, `iat`) and custom application roles/scopes.</p>
        </div>
        <div class="rounded-lg border border-border bg-surface p-4">
          <h4 class="font-semibold text-fg mb-1">3. Signature (Cyan)</h4>
          <p class="text-xs">The cryptographic signature generated by the authorization server to prevent token tampering.</p>
        </div>
        <div class="rounded-lg border border-border bg-surface p-4">
          <h4 class="font-semibold text-fg mb-1">🔒 100% Local Browser Processing</h4>
          <p class="text-xs">Zero network requests, zero telemetry, zero token leaks. Your bearer keys remain 100% private to your session.</p>
        </div>
      </div>
    </article>

    <section aria-labelledby="faq-heading" class="card p-6 md:p-8 space-y-4">
      <h2 id="faq-heading" class="text-xl font-bold text-fg">Frequently Asked Questions (FAQ)</h2>
      <div class="divide-y divide-border rounded-lg border border-border bg-surface">
        {faqs.map((item) => (
          <details class="group">
            <summary class="flex cursor-pointer items-center justify-between gap-4 p-4 text-sm font-medium text-fg [&::-webkit-details-marker]:hidden hover:bg-muted/50">
              <span>{item.q}</span>
              <span class="text-subtle transition-transform group-open:rotate-45 font-bold">＋</span>
            </summary>
            <p class="px-4 pb-4 text-sm text-subtle leading-relaxed">{item.a}</p>
          </details>
        ))}
      </div>
    </section>
  </section>
</BaseLayout>
