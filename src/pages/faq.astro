---
import BaseLayout from '@/layouts/BaseLayout.astro';
import faqData from '@/content/faq.json';
---
<BaseLayout
  title="FAQ — JSON Formatter Pro"
  description="Answers to common questions about JSON Formatter Pro — privacy, file size limits, offline use, and how errors are diagnosed."
  path="/faq"
  includeFaq
>
  <article class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-3xl font-semibold text-fg">Frequently asked questions</h1>
    <p class="mt-2 text-sm text-subtle">
      Common questions about how JSON Formatter Pro works, what it supports, and how it treats your data.
    </p>
    <dl class="mt-8 divide-y divide-border rounded-lg border border-border bg-surface">
      {faqData.map((item) => (
        <div class="p-5">
          <dt class="text-base font-semibold text-fg">{item.q}</dt>
          <dd class="mt-1 text-sm text-subtle">{item.a}</dd>
        </div>
      ))}
    </dl>
  </article>
</BaseLayout>
