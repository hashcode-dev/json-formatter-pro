---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout
  title="Not found — JSON Formatter Pro"
  description="The page you're looking for could not be found."
  path="/404"
>
  <div class="mx-auto flex max-w-lg flex-col items-center px-4 py-24 text-center">
    <h1 class="font-mono text-6xl font-semibold text-fg">404</h1>
    <p class="mt-3 text-sm text-subtle">
      That path doesn't exist. Head back to the formatter to keep working.
    </p>
    <a href="/" class="btn-primary mt-6">Go to formatter</a>
  </div>
</BaseLayout>
