---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { FormatterApp } from "@components/formatter/FormatterApp";

const title = "JSON to CSV Converter - Tabular Data Exporter";
const description =
  "Flatten JSON arrays and objects into clean CSV spreadsheets. Export to Excel or Google Sheets instantly with automatic header detection and quote escaping.";
const keywords =
  "json to csv, convert json to csv, online json to csv converter, json2csv, export json to excel, json to spreadsheet";
---

<BaseLayout title={title} description={description} keywords={keywords} path="/json-to-csv">
  <section class="mx-auto max-w-[1400px] px-4 pt-6">
    <p class="text-xs font-medium uppercase tracking-wide text-subtle">Converter</p>
    <h1 class="mt-1 text-2xl font-semibold tracking-tight text-fg sm:text-3xl">JSON to CSV / TSV Converter</h1>
    <p class="mt-1 max-w-2xl text-sm text-subtle">Flatten JSON objects into tabular CSV format for Microsoft Excel, Google Sheets, and data analysis.</p>
  </section>

  <section class="mx-auto mt-4 h-[calc(100vh-14rem)] min-h-[520px] max-w-[1400px] px-2 sm:px-4">
    <div class="card h-full overflow-hidden shadow-pop">
      <FormatterApp client:only="react" initialMode="csv" />
    </div>
  </section>

  <section class="mx-auto mt-12 max-w-[1400px] px-4 pb-16">
    <article class="card p-6 space-y-6 text-sm text-subtle leading-relaxed">
      <h2 class="text-xl font-bold text-fg">Free Online JSON to CSV Converter</h2>
      <p>
        Flatten nested JSON objects and arrays into tabular <strong>CSV (Comma-Separated Values)</strong> data ready for import into Microsoft Excel, Google Sheets, or data analytics software.
      </p>

      <h3 class="text-lg font-semibold text-fg">Features</h3>
      <ul class="list-disc pl-5 space-y-2">
        <li><strong>Automatic Header Extraction:</strong> Scans all array items to generate comprehensive CSV column headers.</li>
        <li><strong>Quote Escaping:</strong> Safely wraps fields containing commas, double quotes, or line breaks according to RFC 4180 standards.</li>
        <li><strong>Instant Download:</strong> Download exported data directly as a `.csv` file.</li>
      </ul>
    </article>
  </section>
</BaseLayout>
