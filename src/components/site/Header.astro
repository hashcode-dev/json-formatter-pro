---
import { ThemeToggle } from "./ThemeToggle";
import { ToolsDropdown } from "./ToolsDropdown";
---

<header
  class="sticky top-0 z-30 border-b border-border bg-surface/80 backdrop-blur"
>
  <div class="mx-auto flex h-14 max-w-[1400px] items-center gap-3 px-4">
    <a
      href="/"
      class="inline-flex items-center gap-2 text-sm font-semibold text-fg"
    >
      <svg
        class="h-6 w-6"
        viewBox="0 0 32 32"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <rect width="32" height="32" rx="7" fill="rgb(var(--fg))"></rect>
        <path
          d="M11 8c-2 0-3 1-3 3v3c0 1.2-.6 2-2 2v0c1.4 0 2 .8 2 2v3c0 2 1 3 3 3"
          fill="none"
          stroke="rgb(var(--bg))"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
        <path
          d="M21 8c2 0 3 1 3 3v3c0 1.2.6 2 2 2v0c-1.4 0-2 .8-2 2v3c0 2-1 3-3 3"
          fill="none"
          stroke="rgb(var(--bg))"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
        <circle cx="16" cy="16" r="1.75" fill="rgb(var(--bg))"></circle>
      </svg>
      <span>JSON Formatter Pro</span>
    </a>
    <div class="hidden sm:block">
      <ToolsDropdown client:load />
    </div>
    <div class="ml-auto flex items-center gap-2">
      <a
        href="https://github.com/hashcode-dev/json-formatter-pro"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-ghost hidden sm:inline-flex"
        aria-label="View source on GitHub"
      >
        Source
      </a>
      <ThemeToggle client:load />
    </div>
  </div>
</header>
