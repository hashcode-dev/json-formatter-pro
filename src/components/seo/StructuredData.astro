---
import faqData from "@/content/faq.json";

interface Props {
  includeFaq?: boolean;
  customFaq?: Array<{ q: string; a: string }>;
}
const { includeFaq = false, customFaq } = Astro.props;

const siteUrl =
  import.meta.env.PUBLIC_SITE_URL ?? "https://json-formatter-pro.pages.dev";

const webApp = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "JSON Formatter Pro",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Any (browser-based)",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  url: siteUrl,
  description:
    "Fast, private, client-side JSON formatter, validator, beautifier, minifier, and converter tools suite.",
  keywords: "JSON formatter, JSON beautifier, JSON validator, JSON minifier, JSON converter, JSON to YAML, JSON to XML, JSON to CSV, JSON to TypeScript, JWT decoder",
  browserRequirements: "Requires JavaScript and a modern browser.",
  isAccessibleForFree: true,
  inLanguage: "en",
};

const organization = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "JSON Formatter Pro",
  url: siteUrl,
  logo: new URL("/favicon.svg", siteUrl).toString(),
  description:
    "Fast, private, client-side JSON developer tools suite. 100% browser-based with zero server uploads.",
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "Customer Support",
    email: "hashcode.dev@gmail.com",
  },
  sameAs: ["https://github.com/hashcode-dev/json-formatter-pro"],
};

const effectiveFaqData = customFaq || (includeFaq ? faqData : null);

const faq = effectiveFaqData
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: (effectiveFaqData as Array<{ q: string; a: string }>).map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: { "@type": "Answer", text: item.a },
      })),
    }
  : null;
---

<script type="application/ld+json" set:html={JSON.stringify(webApp)} />
<script type="application/ld+json" set:html={JSON.stringify(organization)} />
{faq && <script type="application/ld+json" set:html={JSON.stringify(faq)} />}

