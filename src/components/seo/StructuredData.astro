---
import faqData from "@/content/faq.json";

interface Props {
  includeFaq?: boolean;
}
const { includeFaq = false } = Astro.props;

const siteUrl =
  import.meta.env.PUBLIC_SITE_URL ?? "https://json-formatter-pro.pages.dev";

const webApp = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "JSON Formatter Pro",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Any (browser-based)",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  url: siteUrl,
  description:
    "Fast, private, client-side JSON formatter, validator, beautifier, minifier, and checker. Format, validate, minify JSON online. Includes tree view, diff viewer, JSON parser, syntax checker, and API formatter.",
  keywords: "JSON formatter, JSON beautifier, JSON validator, JSON minifier, JSON checker, JSON cleaner, online JSON formatter, format JSON, JSON parser, JSON converter",
  featureList: [
    "Format JSON",
    "Validate JSON",
    "Beautify JSON",
    "Minify JSON",
    "JSON Lint",
    "JSON Checker",
    "JSON Parser",
    "Tree view",
    "Diff view",
    "Statistics",
    "Sort keys",
    "Remove nulls",
    "Decode unicode escapes",
    "Pretty Print JSON",
    "JSON Debugger",
    "Copy to clipboard",
    "Download JSON",
    "Upload JSON files",
  ],
  browserRequirements: "Requires JavaScript and a modern browser.",
  isAccessibleForFree: true,
  inLanguage: "en",
};

const organization = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "JSON Formatter Pro",
  url: siteUrl,
  logo: new URL("/favicon.svg", siteUrl).toString(),
  description:
    "Fast, private, client-side JSON formatter, validator, beautifier, minifier, and checker. Format JSON online with tree view, diff, and statistics. No data sent to servers.",
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "Customer Support",
    email: "hashcode.dev@gmail.com",
  },
  sameAs: ["https://github.com/hashcode-dev/json-formatter-pro"],
  knowsAbout: [
    "JSON formatting",
    "JSON validation",
    "JSON beautification",
    "JSON minification",
    "JSON parsing",
    "JSON linting",
    "Web development",
    "API testing",
  ],
};

const faq = includeFaq
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: (faqData as Array<{ q: string; a: string }>).map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: { "@type": "Answer", text: item.a },
      })),
    }
  : null;
---

<script type="application/ld+json" set:html={JSON.stringify(webApp)} />
<script type="application/ld+json" set:html={JSON.stringify(organization)} />
{faq && <script type="application/ld+json" set:html={JSON.stringify(faq)} />}
